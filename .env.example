# Copy this file to `.env` and adjust as needed. Never commit `.env`.

# Bearer token required on every /v1/* request (Authorization: Bearer <token>).
# REQUIRED whenever the service is reachable beyond localhost (e.g. a VPS).
# Leave empty only for pure localhost/dev use (the app will warn loudly).
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
VOICEFORGE_API_TOKEN=

# Comma-separated list of allowed browser CORS origins, e.g. the Reel Studio
# dev server. Leave empty if you only call the API from servers/curl/CLI.
VOICEFORGE_CORS_ORIGINS=http://localhost:3000

# Where sample audio / voice artifacts / the SQLite DB live.
VOICEFORGE_DATA_DIR=data
# Where downloaded model checkpoints (Hugging Face cache, etc.) live.
VOICEFORGE_MODELS_DIR=models

# "cpu", "cuda", "mps", or "auto" (auto = CUDA, then Apple MPS, then CPU).
VOICEFORGE_DEVICE=auto

# Comma-separated engine ids enabled for clone/synth in this deployment.
# Empty = established engines only; experimental `voxcpm2` remains disabled.
# Studio still lists every registered engine and marks deployment state.
# VOICEFORGE_ENABLED_ENGINES=openvoice-v2,f5-tts,xtts-v2,qwen3-tts,chatterbox

# Preload models at container startup (faster first synth; adds to cold-start time).
# VOICEFORGE_WARMUP_ENGINES=qwen3-tts,chatterbox

# Modal only — auto-commit voiceforge-data volume after SQLite/voice writes.
# VOICEFORGE_MODAL_DATA_VOLUME=voiceforge-data

# Upload / usage limits.
VOICEFORGE_MAX_UPLOAD_MB=50
VOICEFORGE_MAX_SAMPLES_PER_VOICE=10
VOICEFORGE_MAX_SYNTH_CHARS=5000

# Trim silence / normalize reference uploads before cloning (recommended).
VOICEFORGE_PREPROCESS_SAMPLES=true

# RVC high-fidelity tier (M4) — path to isolated worker venv Python
# VOICEFORGE_RVC_PYTHON=/opt/rvc-venv/bin/python
# VOICEFORGE_RVC_EPOCHS=50
# VOICEFORGE_RVC_BATCH_SIZE=4

# M8 engines — optional sidecars / isolated workers
# Fish Speech self-hosted open-weights API (NOT Fish Audio cloud):
# VOICEFORGE_FISH_SPEECH_URL=http://127.0.0.1:8080
# CosyVoice 3 / IndexTTS2 / Chatterbox worker interpreters:
# VOICEFORGE_COSYVOICE_PYTHON=/opt/cosyvoice-venv/bin/python
# VOICEFORGE_INDEXTTS_PYTHON=/opt/indextts-venv/bin/python
# VOICEFORGE_CHATTERBOX_PYTHON=/opt/chatterbox-venv/bin/python
# VOICEFORGE_CHATTERBOX_MODEL_DIR=/app/models/chatterbox
# VOICEFORGE_QWEN3_TTS_MODEL_DIR=/absolute/path/to/models/qwen3-tts

# Experimental providers — explicit local worker + local snapshot only:
# VOICEFORGE_VOXCPM2_PYTHON=/path/to/voxcpm2-venv/bin/python
# VOICEFORGE_VOXCPM2_MODEL_DIR=/absolute/path/to/models/voxcpm2
# VOICEFORGE_REFERENCE_ASR_PROVIDER=qwen3-asr
# VOICEFORGE_QWEN3_ASR_PYTHON=/path/to/qwen3-asr-venv/bin/python
# VOICEFORGE_QWEN3_ASR_MODEL_DIR=/absolute/path/to/models/qwen3-asr-0.6b
# VOICEFORGE_QWEN3_ALIGNER_MODEL_DIR=/absolute/path/to/models/qwen3-forced-aligner-0.6b

# M7 polish — structured logs and optional synth watermark
# VOICEFORGE_LOG_FORMAT=text
# VOICEFORGE_WATERMARK_ENABLED=false
# VOICEFORGE_WATERMARK_STRENGTH=0.004

VOICEFORGE_LOG_LEVEL=info

# Required (non-interactive) to accept Coqui's Public Model License (CPML)
# for the XTTS-v2 checkpoint at download time. XTTS-v2 is NON-COMMERCIAL /
# research-only under CPML — see README's "Licensing & responsible use"
# section before using this service for anything beyond personal/demo use.
COQUI_TOS_AGREED=1
